+        // Swizzle each 16-byte chunk into 8-bit planar layout.
+        *lo = vec_perm(*lo, *lo, planar);                        // rrrrgggg bbbbaaaa
+        *hi = vec_perm(*hi, *hi, planar);                        // RRRRGGGG BBBBAAAA
