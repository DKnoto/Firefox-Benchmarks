+        __vector unsigned char lo = vec_xl(0, (const unsigned char*)(src + 0));
+        __vector unsigned char hi = vec_xl(0, (const unsigned char*)(src + 4));
+        premul8(&lo, &hi);
+        vec_xst(lo, 0, (unsigned char*)(dst + 0));
+        vec_xst(hi, 0, (unsigned char*)(dst + 4));
+        src += 8; dst += 8; count -= 8;
+    }
